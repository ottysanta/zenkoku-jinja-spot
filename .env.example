##############################################################################
# 全国神社スポット — 環境変数テンプレート
#
# 実運用では以下を複製して運用してください:
#   - ローカル開発         : /.env           (ルート / FastAPI が参照)
#   - Next.js dev          : /apps/web/.env.local
#   - CI                   : GitHub Actions Secrets に直接設定
#   - 本番 (Render / Vercel): それぞれのダッシュボードから設定
##############################################################################

# ========== API (FastAPI) ==========
# SQLite をそのまま使う場合は未設定で OK（apps/api/data/shrine_spots.db）
# Postgres に切り替える場合:
# DATABASE_URL=postgresql+psycopg://shrine:shrine@localhost:5432/shrine
DATABASE_URL=

# 画像アップロード先（Phase 2 で S3/R2 に切替予定）
UPLOAD_DIR=./uploads

# ========== Next.js (apps/web) ==========
# 開発時はローカル API へ向ける
NEXT_PUBLIC_API_BASE=http://localhost:8000
# 旧プロトタイプ地図を iframe で見せるときのパス（同一オリジンの場合 /legacy-map のまま）
NEXT_PUBLIC_LEGACY_MAP_URL=/legacy-map
# SEO 用: 本番公開 URL（canonical / sitemap に使用）
NEXT_PUBLIC_SITE_URL=https://example.com
# sitemap に入れる shrine の最大件数
SITEMAP_LIMIT=2000
# MapLibre スタイル URL（MapTiler 推奨。未設定時は OSM ラスタにフォールバック）
NEXT_PUBLIC_MAP_STYLE=

# ========== 認証 (Phase 1b) ==========
# Auth.js / NextAuth
AUTH_SECRET=            # openssl rand -base64 32 で生成
AUTH_TRUST_HOST=true
# Google OAuth
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
# Email magic link (Resend 経由想定)
AUTH_RESEND_KEY=
AUTH_EMAIL_FROM=no-reply@example.com
# Apple OAuth (Phase 2)
AUTH_APPLE_ID=
AUTH_APPLE_SECRET=

# Next.js → FastAPI のセッション発行橋渡し用共有シークレット
#   - FastAPI 側: AUTH_BRIDGE_SECRET
#   - Next.js 側: AUTH_BRIDGE_SECRET（同じ値）と API_BASE_URL_INTERNAL（SSR からの内部宛先）
AUTH_BRIDGE_SECRET=                      # openssl rand -base64 32
API_BASE_URL_INTERNAL=http://localhost:8000
# API 側セッション有効期限（秒）
AUTH_SESSION_TTL_SEC=2592000             # 30日

# ========== 決済 Stripe (Phase 1f) ==========
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe からの成功/キャンセル戻り先 URL。{OFFERING_ID} は自前プレースホルダ、
# {CHECKOUT_SESSION_ID} は Stripe の公式プレースホルダ。
STRIPE_SUCCESS_URL=http://localhost:3030/offerings/success?offering_id={OFFERING_ID}&session_id={CHECKOUT_SESSION_ID}
STRIPE_CANCEL_URL=http://localhost:3030/offerings/cancel
# 月次まとめ精算の最低振込単位（円）
OFFERING_PAYOUT_MIN_JPY=1000
# サービス手数料（%）: 0.08 = 8%
OFFERING_FEE_RATE=0.08

# ========== 翻訳 (Phase 2) ==========
DEEPL_API_KEY=

# ========== 通知 (Phase 1e) ==========
RESEND_API_KEY=

# ========== Postgres (docker-compose) ==========
POSTGRES_DB=shrine
POSTGRES_USER=shrine
POSTGRES_PASSWORD=shrine
PGADMIN_EMAIL=admin@example.com
PGADMIN_PASSWORD=admin

# ========== 運用 ==========
SENTRY_DSN=
LOG_LEVEL=info
