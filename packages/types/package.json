{
  "name": "@shrine-spots/types",
  "version": "0.1.0",
  "private": true,
  "description": "apps/api の OpenAPI から自動生成する共有 TypeScript 型。openapi-typescript で生成する。",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "scripts": {
    "generate": "openapi-typescript http://localhost:8000/openapi.json -o ./src/openapi.d.ts",
    "generate:file": "openapi-typescript ../../apps/api/openapi.json -o ./src/openapi.d.ts"
  },
  "devDependencies": {
    "openapi-typescript": "^7.4.4"
  }
}
